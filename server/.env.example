# ============================================================================
# 🔐 ПЕРЕМЕННЫЕ ОКРУЖЕНИЯ ДЛЯ MESSENGER SERVER
# ============================================================================
# Скопируйте этот файл в .env и заполните значениями для вашего сервера
# ============================================================================

# -----------------------------------------------------------------------------
# 🌐 PORT
# -----------------------------------------------------------------------------
# Порт, на котором будет запущен WebSocket сервер
# По умолчанию: 3000
PORT=3000

# -----------------------------------------------------------------------------
# 🗄️ DATABASE_URL (Railway PostgreSQL)
# -----------------------------------------------------------------------------
# Строка подключения к PostgreSQL базе данных
# Формат: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
# 
# 🔹 Как получить:
# 1. Зайдите в проект Railway → PostgreSQL
# 2. Перейдите во вкладку "Variables"
# 3. Скопируйте значение DATABASE_URL
# 
# Пример для Railway:
# DATABASE_URL=postgresql://user:password@tramway.proxy.rlwy.net:58954/railway?sslmode=require
DATABASE_URL=your_database_url_here

# -----------------------------------------------------------------------------
# 🌍 NODE_ENV
# -----------------------------------------------------------------------------
# Окружение: development или production
# В production включается SSL для базы данных
# 
# 🔹 Значения:
# - development: локальная разработка, SSL отключен
# - production: продакшен, SSL включен
NODE_ENV=production

# -----------------------------------------------------------------------------
# 🔒 Дополнительные переменные (опционально)
# -----------------------------------------------------------------------------
# Если вы хотите использовать отдельные переменные вместо DATABASE_URL:

# PGUSER=your_username
# PGPASSWORD=your_password
# PGDATABASE=your_database
# PGHOST=tramway.proxy.rlwy.net
# PGPORT=58954

# ============================================================================
# 📋 ИНСТРУКЦИЯ ПО НАСТРОЙКЕ
# ============================================================================
# 
# 1️⃣ ЛОКАЛЬНАЯ РАЗРАБОТКА:
#    - Создайте файл .env в папке server/
#    - Укажите PORT=3000
#    - Укажите DATABASE_URL для локальной PostgreSQL
#    - Установите NODE_ENV=development
# 
# 2️⃣ DEPLOY НА RAILWAY:
#    - Добавьте переменные окружения в Railway Dashboard:
#      * DATABASE_URL (автоматически создаётся Railway)
#      * NODE_ENV=production
#    - Не нужно загружать .env файл на Railway!
# 
# 3️⃣ БЕЗОПАСНОСТЬ:
#    - ⚠️ НИКОГДА не коммитьте файл .env в Git
#    - ⚠️ Этот файл .env.example уже в .gitignore
#    - ✅ Храните секреты в менеджере паролей
# 
# ============================================================================
# 🔗 ПОЛЕЗНЫЕ ССЫЛКИ
# ============================================================================
# - Документация Railway: https://docs.railway.app/
# - PostgreSQL на Railway: https://docs.railway.app/databases/postgresql
# - Переменные окружения: https://docs.railway.app/develop/variables
